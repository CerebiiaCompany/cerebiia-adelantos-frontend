# Dev: proxy Vite reenvía /api → http://localhost:8000
VITE_API_URL=/api/v1

# Producción / sin proxy:
# VITE_API_URL=https://api.tudominio.com/api/v1

VITE_APP_ENV=development

# Ventana de fechas del adelanto (días 1–20 del mes).
# true = permite solicitar en cualquier fecha (solo para pruebas de integración)
# false o omitir = regla de negocio normal
VITE_BYPASS_ADELANTO_DATE_WINDOW=true
